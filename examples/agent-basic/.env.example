# Copy to .env and edit. The stub backend needs none of these.

# Backend: "stub" (default, no API key) or "ag2" (real AutoGen 2 agent).
AGENT_BACKEND=stub

# --- ag2 backend only ---
# OPENAI_API_KEY=sk-...
# AGENT_MODEL=gpt-4o-mini

# --- server bind (optional) ---
# AGENT_HOST=0.0.0.0
# AGENT_PORT=8000

# Secret the stub agent emits, so Agate can demonstrate redaction. Keeping the
# "sk-" prefix lets the demo policy `redact = ["sk-"]` mask it.
# AGENT_DEMO_SECRET=sk-EXAMPLE-DEMO-SECRET-1234567890
