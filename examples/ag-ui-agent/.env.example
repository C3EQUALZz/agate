# Copy to .env and adjust. No secrets are required for the default stub backend.

# Backend: "stub" (offline, scripted, no API key) or "ag2" (real autogen.beta).
AGENT__BACKEND=stub

# Real-AG2 backend only (AGENT__BACKEND=ag2, requires `uv sync --extra ag2`):
# AGENT__OPENAI_API_KEY=sk-your-openai-api-key
# AGENT__OPENAI_MODEL=gpt-4o-mini
# Optional proxy for regions where api.openai.com is blocked:
# AGENT__OPENAI_PROXY_URL=http://user:pass@proxy.example.com:8080

# Logging
AGENT__LOG_LEVEL=INFO
AGENT__LOG_JSON=false
