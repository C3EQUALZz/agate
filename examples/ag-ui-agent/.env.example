# Copy to .env and adjust. An API key is REQUIRED: the agent drives a real
# autogen.beta (AG2) model — there is no offline mode.

AGENT__OPENAI_API_KEY=sk-your-openai-api-key
AGENT__OPENAI_MODEL=gpt-4o-mini

# Target any OpenAI-compatible provider by setting the base URL. Leave unset for
# OpenAI. For Mistral, use its OpenAI-compatible endpoint and a Mistral model:
#   AGENT__OPENAI_BASE_URL=https://api.mistral.ai/v1
#   AGENT__OPENAI_API_KEY=your-mistral-api-key
#   AGENT__OPENAI_MODEL=mistral-small-latest

# Optional proxy for regions where the API host is blocked:
# AGENT__OPENAI_PROXY_URL=http://user:pass@proxy.example.com:8080

# Logging
AGENT__LOG_LEVEL=INFO
AGENT__LOG_JSON=false
